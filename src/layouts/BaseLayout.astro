---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** 当前激活的导航项；默认根据路径自动判断 */
  activeNav?: 'blog' | 'about' | 'none';
}

const { title, description, activeNav } = Astro.props;

const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname;

// 默认根据路径判断 about 高亮；博客链接在非 about 页时高亮
const isAbout = path.startsWith(base + 'about');
const resolvedActive = activeNav ?? (isAbout ? 'about' : 'blog');

const pageTitle = title || 'AI 应用开发工程师 · 个人简历与博客';
const pageDesc = description || '7 年软件开发经验，从工程交付到 AI 应用构建。Python、Node.js、Vue — 独立完成全栈 AI 项目从 0 到 1。';
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet">
  <script is:inline>
    /* 阻塞脚本：在 body 渲染前应用保存的主题，避免主题闪动 */
    (function(){
      var t = localStorage.getItem('theme');
      if(t === 'dark') document.documentElement.setAttribute('data-theme','dark');
    })();
  </script>
</head>
<body>
  <header class="topbar">
    <a class="brand" href={base}><span class="dot" aria-hidden="true"></span><span class="brand-name">个人站点</span></a>
    <nav class="topnav">
      <a href={base} class={resolvedActive === 'blog' ? 'is-active' : ''}>博客</a>
      {/* <a href={`${base}about/`} class={resolvedActive === 'about' ? 'is-active' : ''}>关于我</a> */}
      <button class="theme-toggle" id="themeToggle" aria-label="切换主题">
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
      </button>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <p>© 2026 · <span>Built from scratch</span> · Crafted with care</p>
  </footer>

  <script>
    /* Theme Toggle — default 晨(light)；夜(dark)。初始主题已在 <head> 中应用。 */
    (function(){
      const root = document.documentElement;
      const toggle = document.getElementById('themeToggle');
      toggle.addEventListener('click', () => {
        if(root.getAttribute('data-theme') === 'dark'){
          root.removeAttribute('data-theme');
          localStorage.setItem('theme','light');
        }else{
          root.setAttribute('data-theme','dark');
          localStorage.setItem('theme','dark');
        }
      });
    })();

    /* Scroll Reveal */
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if(entry.isIntersecting){
          entry.target.classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -50px 0px' });
    document.querySelectorAll('[data-reveal]').forEach(el => revealObserver.observe(el));
  </script>
</body>
</html>
